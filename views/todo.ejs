<!DOCTYPE html>
<html lang="en">
    <head>
        <title>My DevOps Todo</title>
        <style>
            * { box-sizing: border-box; margin: 0; padding: 0; }
            body {
                font-family: 'Segoe UI', sans-serif;
                background: #0f0f1a;
                color: #e0e0e0;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                align-items: center;
                padding: 40px 20px;
            }
            h1 {
                font-size: 28px;
                font-weight: 600;
                color: #00e5ff;
                margin-bottom: 8px;
                letter-spacing: 1px;
            }
            .subtitle {
                font-size: 13px;
                color: #555;
                margin-bottom: 30px;
            }
            .container { width: 100%; max-width: 520px; }
            ul { list-style: none; margin-bottom: 20px; }
            ul li {
                background: #1a1a2e;
                border: 1px solid #2a2a4a;
                border-radius: 8px;
                padding: 14px 90px 14px 16px;
                margin-bottom: 10px;
                position: relative;
                font-size: 15px;
                transition: border-color 0.2s;
            }
            ul li:hover { border-color: #00e5ff44; }
            ul li a { text-decoration: none; font-size: 16px; }
            .delete-btn {
                position: absolute; right: 14px; top: 50%;
                transform: translateY(-50%);
                color: #ff4d6d;
            }
            .edit-btn {
                position: absolute; right: 44px; top: 50%;
                transform: translateY(-50%);
                color: #ffd60a;
            }
            form {
                background: #1a1a2e;
                border: 1px solid #2a2a4a;
                border-radius: 10px;
                padding: 20px;
            }
            label {
                display: block;
                font-size: 13px;
                color: #888;
                margin-bottom: 10px;
                text-transform: uppercase;
                letter-spacing: .05em;
            }
            input[type="text"] {
                width: 100%;
                padding: 10px 14px;
                background: #0f0f1a;
                border: 1px solid #2a2a4a;
                border-radius: 6px;
                color: #e0e0e0;
                font-size: 14px;
                margin-bottom: 12px;
                outline: none;
            }
            input[type="text"]:focus { border-color: #00e5ff; }
            input[type="submit"] {
                width: 100%;
                padding: 10px;
                background: #00e5ff;
                color: #0f0f1a;
                border: none;
                border-radius: 6px;
                font-size: 14px;
                font-weight: 600;
                cursor: pointer;
                transition: opacity 0.2s;
            }
            input[type="submit"]:hover { opacity: 0.85; }
        </style>
    </head>
    <body>
        <div class="container">
            <h1>⚡ DevOps Todo</h1>
            <p class="subtitle">Built with Node.js · Dockerized · CI/CD with GitHub Actions</p>
            <ul>
                <% todolist.forEach(function(todo, index) { %>
                <li>
                    <a href="/todo/delete/<%= index %>" class="delete-btn">✘</a>
                    <a href="/todo/<%= index %>" class="edit-btn">✎</a>
                    <%- todo %>
                </li>
                <% }); %>
            </ul>
            <form action="/todo/add/" method="post">
                <label for="newtodo">Add a new task</label>
                <input type="text" name="newtodo" id="newtodo" placeholder="e.g. Learn GitHub Actions..." autofocus />
                <input type="submit" value="Add Task" />
            </form>
        </div>
    </body>
</html>